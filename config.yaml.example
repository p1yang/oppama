# Oppama 生产环境配置示例
# 复制此文件为 config.yaml 并根据实际情况修改

server:
    # 服务器监听地址
    # 0.0.0.0 表示监听所有网卡（生产环境推荐）
    host: 0.0.0.0
    port: 9001
    mode: release  # debug, release, test
    
    # HTTPS 配置
    # ⚠️  生产环境强烈建议使用正式 CA 证书
    enable_https: true
    
    # Let's Encrypt 证书路径（推荐）
    cert_file: "/etc/letsencrypt/live/your-domain.com/fullchain.pem"
    key_file: "/etc/letsencrypt/live/your-domain.com/privkey.pem"
    
    # 或使用自签名证书（仅测试环境）
    # cert_file: "./certs/server.crt"
    # key_file: "./certs/server.key"
    
    # TLS 版本配置
    min_tls_version: "1.2"  # 1.0, 1.1, 1.2, 1.3
    
    # AutoTLS（暂未实现，预留）
    auto_tls: false
    tls_domains: ""

proxy:
    enabled: true
    enable_auth: true
    api_key: "YOUR_STRONG_API_KEY_HERE"  # ⚠️  请修改为强随机密钥
    default_model: ""
    fallback_enabled: true
    max_retries: 3
    timeout: 120
    rate_limit:
        enabled: true
        requests_per_minute: 100  # 根据实际需求调整
    # HTTP 代理配置（如需要访问后端服务）
    http_proxy: ""
    https_proxy: ""
    no_proxy: ""

auth:
    enabled: true
    jwt_secret: "CHANGE_THIS_TO_A_STRONG_RANDOM_SECRET"  # ⚠️  必须修改
    jwt_expire: 24h
    enable_blacklist: true
    blacklist_ttl: 24h
    password_policy:
        min_length: 10          # 生产环境建议 10+
        require_upper: true
        require_lower: true
        require_numbers: true
        require_special: true   # 生产环境建议启用
    login_rate_limit:
        max_attempts: 5         # 生产环境建议更严格
        window_minutes: 15
        lockout_minutes: 60
    session_timeout: 168h

cors:
    # ⚠️  生产环境请明确指定允许的域名
    allowed_origins:
        - "https://your-domain.com"
        - "https://www.your-domain.com"
    allowed_methods:
        - GET
        - POST
        - PUT
        - DELETE
        - OPTIONS
    allowed_headers:
        - Origin
        - Content-Type
        - Authorization
        - X-Requested-With
    allow_credentials: true
    max_age: 86400

detector:
    concurrency: 20            # 根据服务器性能调整
    timeout: 30
    check_interval: 600        # 健康检查间隔（秒）
    model_sync_interval: 600   # 模型同步间隔（秒）
    honeypot_detection:
        enabled: true
        suspicious_ports:
            - 8080
            - 8888
            - 9000
            - 11434
        fake_versions:
            - 0.0.0
            - unknown
        threshold: 60          # 蜜罐判定阈值

discovery:
    auto_discovery:
        enabled: false
        interval: 3600
    engines:
        fofa:
            enabled: false
            email: ""
            key: ""
            query: 'port="11434"'
            max_results: 100
        hunter:
            enabled: false
            key: ""
            query: 'port="11434"'
            max_results: 100
        shodan:
            enabled: false
            key: ""
            query: 'http.title:"Ollama"'
            max_results: 100

storage:
    type: sqlite
    sqlite:
        path: "./data/oppama.db"
    postgres:
        host: ""
        port: 0
        database: ""
        user: ""
        password: ""
    
    # 数据保留策略
    retention_days: 90  # 生产环境可适当延长
    
    # 数据库连接池配置（根据服务器性能调整）
    pool:
        max_open_conns: 50       # 最大连接数
        max_idle_conns: 10       # 空闲连接数
        conn_max_lifetime: 1800  # 连接生命周期（秒）
        conn_max_idle_time: 300  # 空闲超时（秒）

log:
    level: info              # 生产环境建议 info，调试时用 debug
    format: json             # json 便于日志分析系统收集
    output: "./logs/server.log"
    max_size: 200            # MB，单个日志文件最大值
    max_backups: 10          # 保留的旧日志文件数
    max_age: 60              # 天，日志保留时间

# 监控和告警配置（预留）
monitoring:
    enabled: false
    prometheus_port: 9090
    metrics_path: "/metrics"

# 备份配置（预留）
backup:
    enabled: false
    interval: 86400          # 秒，每天备份一次
    backup_dir: "./backups"
    retention_days: 30
