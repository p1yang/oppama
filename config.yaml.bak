# 服务器配置
server:
    # 监听地址：0.0.0.0 表示监听所有网络接口
    host: 0.0.0.0
    # 监听端口
    port: 8080
    # 运行模式：release（生产模式）或 debug（调试模式）
    mode: release

# 代理配置
proxy:
    # 是否启用代理服务
    enabled: true
    # 是否启用代理认证
    enable_auth: true
    # API 密钥，用于代理认证
    api_key: admin123
    # 默认使用的模型名称
    default_model: ""
    # 是否启用故障转移（当某个服务不可用时自动切换到其他服务）
    fallback_enabled: true
    # 最大重试次数
    max_retries: 3
    # 请求超时时间（秒）
    timeout: 120
    # 速率限制配置
    rate_limit:
        # 是否启用速率限制
        enabled: false
        # 每分钟允许的最大请求数
        requests_per_minute: 60
    # HTTP 代理地址
    http_proxy: ""
    # HTTPS 代理地址
    https_proxy: ""
    # 不使用代理的地址列表
    no_proxy: ""
# 认证配置
auth:
    # 是否启用认证
    enabled: true
    # JWT 令牌密钥（生产环境中请修改此默认值）
    jwt_secret: change-this-secret-in-production
    # JWT 令牌有效期
    jwt_expire: 24h
    # 是否启用黑名单（用于登出时将被禁用的令牌加入黑名单）
    enable_blacklist: true
    # 黑名单有效期
    blacklist_ttl: 24h
    # 密码策略配置
    password_policy:
        # 最小密码长度
        min_length: 8
        # 是否要求包含大写字母
        require_upper: true
        # 是否要求包含小写字母
        require_lower: true
        # 是否要求包含数字
        require_numbers: true
        # 是否要求包含特殊字符
        require_special: false
    # 登录速率限制（防止暴力破解）
    login_rate_limit:
        # 最大尝试次数
        max_attempts: 20
        # 时间窗口（分钟）
        window_minutes: 5
        # 锁定时间（分钟）
        lockout_minutes: 30
    # Session 会话超时时间
    session_timeout: 168h
# CORS（跨域资源共享）配置
cors:
    # 允许的源地址列表（前端应用地址）
    allowed_origins:
        - http://localhost:5173
        - http://localhost:8080
    # 允许的 HTTP 方法
    allowed_methods:
        - GET
        - POST
        - PUT
        - DELETE
        - OPTIONS
    # 允许的请求头
    allowed_headers:
        - Origin
        - Content-Type
        - Authorization
    # 是否允许携带凭证（如 Cookie、Authorization 头等）
    allow_credentials: false
    # 预检请求结果的缓存时间（秒）
    max_age: 86400
# 检测器配置（用于检测服务可用性和蜜罐识别）
detector:
    # 并发检测数量
    concurrency: 10
    # 检测超时时间（秒）
    timeout: 30
    # 检查间隔时间（秒）
    check_interval: 3600
    # 模型同步间隔时间（秒）
    model_sync_interval: 3600
    # 蜜罐检测配置
    honeypot_detection:
        # 是否启用蜜罐检测
        enabled: true
        # 可疑端口列表（这些端口常见于蜜罐）
        suspicious_ports:
            - 8080
            - 8888
            - 9000
        # 伪版本标识（如果服务返回这些版本号，可能是蜜罐）
        fake_versions:
            - 0.0.0
            - unknown
        # 阈值（超过此值则判定为蜜罐）
        threshold: 10
# 服务发现配置（用于自动发现 Ollama 服务）
discovery:
    # 自动发现配置
    auto_discovery:
        # 是否启用自动发现
        enabled: false
        # 发现间隔时间（秒）
        interval: 3600
    # 搜索引擎配置
    engines:
        # FOFA 搜索引擎配置
        fofa:
            # 是否启用 FOFA
            enabled: false
            # FOFA 邮箱
            email: ""
            # FOFA API 密钥
            key: ""
            # 搜索查询语句
            query: port="11434"
            # 最大结果数量
            max_results: 100
        # Hunter 搜索引擎配置
        hunter:
            # 是否启用 Hunter
            enabled: false
            # Hunter API 密钥
            key: 5837e59cacced34bcfd3d15bc343e7f4a07696cafe11d8e6de04c68341931b23
            # 搜索查询语句
            query: port="11434"
            # 最大结果数量
            max_results: 100
        # Shodan 搜索引擎配置
        shodan:
            # 是否启用 Shodan
            enabled: false
            # Shodan API 密钥
            key: Su5MSEONomqumcQd4gFmWlk2izdsNafA
            # 搜索查询语句
            query: http.title:"Ollama"
            # 最大结果数量
            max_results: 100
# 存储配置
storage:
    # 存储类型：sqlite 或 postgres
    type: sqlite
    # SQLite 配置
    sqlite:
        # 数据库文件路径
        path: ./data/oppama.db
    # PostgreSQL 配置
    postgres:
        # 数据库主机地址
        host: ""
        # 数据库端口
        port: 0
        # 数据库名称
        database: ""
        # 数据库用户名
        user: ""
        # 数据库密码
        password: ""
    # 数据保留天数（超过此天数的数据会被清理）
    retention_days: 30
# 日志配置
log:
    # 日志级别：debug, info, warn, error
    level: info
    # 日志格式：json 或 text
    format: json
    # 日志输出文件路径
    output: ./logs/server.log
    # 单个日志文件最大大小（MB）
    max_size: 100
    # 最大备份文件数量
    max_backups: 5
    # 日志文件最大保留天数
    max_age: 30
